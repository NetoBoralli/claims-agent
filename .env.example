# --- LLM backend -----------------------------------------------------------
# Swap providers without touching agent code (see src/llm/index.ts).
LLM_PROVIDER=ollama

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Per-agent model overrides. Leave unset to fall back to OLLAMA_MODEL.
# CLASSIFIER_MODEL=qwen2.5:7b
# DECIDER_MODEL=llama3.1:8b
# RESPONDER_MODEL=qwen2.5:7b

# Hosted API alternative — flip LLM_PROVIDER=openai to use it.
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# --- Runtime ---------------------------------------------------------------
# Where mock tools (Zendesk/Slack) append their side effects.
RUN_DIR=.runs
